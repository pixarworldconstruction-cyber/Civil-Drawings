{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role (admin or user)" },
        "displayName": { "type": "string", "description": "User's display name" },
        "mobileNumber": { "type": "string", "description": "User's mobile number" },
        "walletBalance": { "type": "number", "description": "User's wallet balance in coins" },
        "referralCode": { "type": "string", "description": "User's unique referral code" },
        "referralCount": { "type": "number", "description": "Number of users referred" },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user" },
        "isWelcomeBonusClaimed": { "type": "boolean", "description": "Whether the welcome bonus has been claimed" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A civil construction project",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "userId": { "type": "string", "description": "UID of the contractor who owns the project" },
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Project creation timestamp" }
      },
      "required": ["id", "userId", "name", "createdAt"]
    },
    "Image": {
      "title": "Image",
      "description": "A work image uploaded for a project",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the image" },
        "projectId": { "type": "string", "description": "ID of the project this image belongs to" },
        "url": { "type": "string", "format": "uri", "description": "URL of the image (base64 or external)" },
        "caption": { "type": "string", "description": "Image caption" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Image upload timestamp" }
      },
      "required": ["id", "projectId", "url", "createdAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "A bill generated for a project",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the bill" },
        "userId": { "type": "string", "description": "UID of the user who owns the bill" },
        "projectId": { "type": "string", "description": "ID of the project this bill belongs to" },
        "projectName": { "type": "string", "description": "Name of the project" },
        "amount": { "type": "number", "description": "Base amount in coins" },
        "gst": { "type": "number", "description": "GST amount (18%)" },
        "total": { "type": "number", "description": "Total amount including GST" },
        "discount": { "type": "number", "description": "Discount amount" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Bill generation timestamp" }
      },
      "required": ["id", "userId", "projectId", "projectName", "amount", "gst", "total", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Civil construction projects"
    },
    "/images/{imageId}": {
      "schema": "Image",
      "description": "Work images for projects"
    },
    "/bills/{billId}": {
      "schema": "Bill",
      "description": "Project bills"
    }
  }
}
